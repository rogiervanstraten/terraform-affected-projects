{
  "name": "terraform-affected-projects",
  "description": "GitHub Action to detect affected Terraform projects in monorepos based on module dependencies",
  "version": "0.0.0",
  "author": "Rogier van Straten <rogier@from89.com>",
  "type": "module",
  "private": true,
  "homepage": "https://github.com/rogiervanstraten/terraform-affected-projects",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogiervanstraten/terraform-affected-projects.git"
  },
  "bugs": {
    "url": "https://github.com/rogiervanstraten/terraform-affected-projects/issues"
  },
  "keywords": [
    "actions",
    "terraform",
    "changed-files",
    "monorepo"
  ],
  "exports": {
    ".": "./dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "bundle": "npm run format:write && npm run package",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "format:write": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "lint": "npx eslint .",
    "local-action": "npx @github/local-action . src/main.ts .env",
    "package": "npx rollup --config rollup.config.ts --configPlugin @rollup/plugin-typescript",
    "package:watch": "npm run package -- --watch",
    "all": "npm run format:write && npm run lint && npm run test && npm run package"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "minimatch": "^10.2.4"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.0",
    "@github/local-action": "^6.0.2",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^20.19.25",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.29.1",
    "@vitest/ui": "^4.0.14",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "make-coverage-badge": "^1.2.0",
    "prettier": "^3.7.3",
    "prettier-eslint": "^16.4.2",
    "rollup": "^4.53.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.9"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  },
  "overrides": {
    "@octokit/plugin-paginate-rest": "^11.3.6",
    "@octokit/request": "^9.1.3",
    "@octokit/request-error": "^6.1.5"
  }
}
